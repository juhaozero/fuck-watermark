[server]
addr = 8080
# HTTP 上游请求超时（秒）
request_timeout = 15

[weibo]
# 微博视频代理基址（可选，防 403），例如 "https://svproxy.example.com"
proxy_base = ""

[douyin]
cookie = ""

[security]
# API 访问密钥；留空则关闭鉴权（仅建议内网或开发环境）
api_key = ""
# CORS 允许来源，"*" 表示任意来源
allow_origins = ["*"]
# 请求体大小上限（字节），含 cookie 字段时需适当增大
max_body_bytes = 16384

[rate_limit]
# 是否启用按 IP 限流（仅作用于 /api/*）
enabled = true
requests_per_minute = 60
burst = 10


[log]
level = "info"
# 日志级别: debug / info / warn / error
format = "json"
# 输出格式: json / console
log_path = "tmp/logs"
filename = "app"
max_size = 100
# 单文件最大 MB
max_backups = 10
max_age = 7
compress = true
console = true
is_debug = false